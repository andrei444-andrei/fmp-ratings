# --- База данных (libSQL / Turso) ---
# Прод: создать БД на Turso и подставить URL + токен.
#   turso db create portfolio-pnl
#   turso db show portfolio-pnl --url
#   turso db tokens create portfolio-pnl
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Локальная разработка: файл SQLite (если задан — перекрывает Turso).
LOCAL_SQLITE_PATH=./local.db

# --- AI-гейт aimlapi.com (OpenAI-совместимый) ---
# Ключ: https://aimlapi.com/app/keys
AIMLAPI_KEY=

# Модель по умолчанию для AI-парсинга (если не задана — gpt-4o-mini).
# Список: https://aimlapi.com/models  (примеры: gpt-4o, gpt-4.1, claude-3-5-sonnet-20241022)
# AIMLAPI_MODEL=gpt-4o-mini
