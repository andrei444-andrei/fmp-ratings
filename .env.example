# Required: FinancialModelingPrep API key (Starter+ for historical-mcap, sp500_constituent)
FMP_API_KEY=

# Required for production: Turso database (libSQL).
# Get these via:  turso db create fmp-ratings  &&  turso db show fmp-ratings --url  &&  turso db tokens create fmp-ratings
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: use a local SQLite file for development (overrides Turso if set)
# LOCAL_SQLITE_PATH=./local.db

# aimlapi.com key (OpenAI-совместимый агрегатор) — нужен для:
#   - /heatmap (AI-новости дня, помесячный батч событий)
#   - /market-events (AI-кластеризация GDELT-статей в события)
AIMLAPI_KEY=

# Marketaux News API token — нужен для:
#   - /heatmap (источник заголовков для /api/ai/news)
#   - /heatmap (поиск событий диапазона через /api/events/month-news)
#   - /admin/marketaux (отладочный конструктор запросов)
# Получить: https://www.marketaux.com/account/dashboard
MARKETAUX_KEY=

# Optional: месячный safety-cap вызовов Marketaux. По умолчанию 8000.
# MARKETAUX_MONTHLY_CAP=8000

# NewsAPI.ai / Event Registry — для /admin/newsapi-ai (отладка).
# Эндпоинт event/getEvents даёт автокластеризованные СОБЫТИЯ (не поиск),
# отсортированные по охвату — то что нужно для «важных событий».
# Получить: https://www.newsapi.ai/dashboard
NEWSAPI_AI_KEY=
