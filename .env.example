# Required: FinancialModelingPrep API key (Starter+ for historical-mcap, sp500_constituent)
FMP_API_KEY=

# Required for production: Turso database
# Get these via:  turso db create fmp-ratings  &&  turso db show fmp-ratings --url  &&  turso db tokens create fmp-ratings
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: use a local SQLite file for development (overrides Turso if set)
# LOCAL_SQLITE_PATH=./local.db

# aimlapi.com key (OpenAI-совместимый агрегатор): нужен для /heatmap (AI-новости дня)
# и /market-events (AI-поиск исторических событий).
AIMLAPI_KEY=
