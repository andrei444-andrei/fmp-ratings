# Required: FinancialModelingPrep API key — данные для раздела «Исследование трендов»
# (дневные цены, фундаментал, дивиденды).
FMP_API_KEY=

# Optional: EODHD (eodhd.com) — если задан, СТАНОВИТСЯ основным источником цен/составов для /signals:
# скорректированные цены (adjusted_close → чистые бары), широкое гео (вкл. Бразилию B3) и составы бирж.
# Без ключа всё работает на FMP. План «EOD Historical Data» (~$19.99/мес) покрывает нужное.
EODHD_API_KEY=

# Required for production: Turso database (libSQL).
# Get these via:  turso db create market-lab  &&  turso db show market-lab --url  &&  turso db tokens create market-lab
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: use a local SQLite file for development (overrides Turso if set)
# LOCAL_SQLITE_PATH=./local.db

# aimlapi.com key (OpenAI-совместимый агрегатор) — нужен для AI-генерации Python-кода
# в разделе «Исследование трендов» (/research).
AIMLAPI_KEY=

# Единая модель для AI-запросов (если не задана — дефолт в коде).
# Список моделей: https://aimlapi.com/models
# AIMLAPI_MODEL=gpt-4o

# QuantConnect: креды НЕ задаются здесь — они вводятся в админке (/admin/quantconnect)
# и хранятся в БД (таблица qc_credentials).
